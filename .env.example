# Copy this file to .env and fill in your values from:
# Supabase Dashboard → Settings → API

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# NOTE: Never put the service_role key here.
# The service_role key bypasses all security rules and must never be in client code.

# ── HekBot Edge Function secrets ─────────────────────────────────────
# Set these in Supabase Dashboard → Edge Functions → Manage secrets
# (NOT in this file — these are server-side only)
#
# ANTHROPIC_API_KEY=sk-ant-...
#
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are auto-injected
# by Supabase into every Edge Function — you do not need to set them.
