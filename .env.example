# Copy this file to .env and fill in your values from:
# Supabase Dashboard → Settings → API

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# NOTE: Never put the service_role key here.
# The service_role key bypasses all security rules and must never be in client code.
